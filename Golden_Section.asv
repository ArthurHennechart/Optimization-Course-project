function x_opt = Golden_Section(f, a, b, eps)

% the golden ratio
phi=(1+sqrt(5))/2;

% the main loop with the stopping point being the critera b-a <= eps
while b-a > eps
    % x1 = b - (b-1)/golden ration
    % x2 = a + (b -

    x1= b - (b-a)/phi;
    x2= a + (b-a)/phi;
    
    % update a or b accordingly 
    if f(x2) > f(x1)
        b=x2;
    else
        a=x1;
    end
end

% the final result
x_opt = (a+b)/2;

end